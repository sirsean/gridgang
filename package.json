{
  "name": "gridgang",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "assets:cells": "node scripts/generate-cell-assets.mjs",
    "assets:inspector": "node scripts/generate-inspector-assets.mjs",
    "assets:home": "node scripts/generate-home-assets.mjs",
    "assets:share": "node scripts/generate-share-assets.mjs",
    "assets:conveyor": "node scripts/generate-conveyor-belt-assets.mjs",
    "assets:audio": "node scripts/generate-audio-assets.mjs",
    "preview": "vite preview",
    "deploy": "vite build && wrangler deploy",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "phaser": "^4.0.0"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.31.2",
    "@cloudflare/workers-types": "^4.20260412.1",
    "sharp": "^0.34.5",
    "typescript": "^6.0.2",
    "vite": "^8.0.8",
    "wrangler": "^4.81.1"
  }
